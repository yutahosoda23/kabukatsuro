# .env.example - 環境変数テンプレート（コピーして .env.local を作成）
# 好材料/午後候補は無料の公開ページから取得するためAPIキーは不要

# Gmail送信設定（送信元のGmailアドレスとGoogleアプリパスワード）
# アプリパスワード取得: https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# 送信先メールアドレス（カンマ区切りで複数指定可）
TO_EMAIL=your-email@gmail.com,another@gmail.com
